{
  "name": "n-cafe-auto",
  "version": "1.2.3",
  "description": "네이버 카페 자동 등록 Electron 앱",
  "main": "src/main/index.js",
  "scripts": {
    "start": "chcp 65001 >nul && electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "puppeteer-core": "^22.6.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "extends": null,
    "appId": "com.ncafeauto.app",
    "productName": "N Cafe Auto",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/adb",
        "to": "adb",
        "filter": ["adb.exe", "AdbWinApi.dll", "AdbWinUsbApi.dll"]
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "lazy5186-lgtm",
      "repo": "N-cafe-auto"
    },
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico",
      "requestedExecutionLevel": "requireAdministrator",
      "artifactName": "NCafeAuto-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
